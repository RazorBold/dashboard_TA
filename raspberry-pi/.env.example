# .env — Konfigurasi Raspberry Pi
# Salin jadi .env: cp .env.example .env

# ID gateway — HARUS sama dengan Gateway ID di dashboard
GATEWAY_ID=GW-001

# IP publik VM + port MQTT publik
MQTT_HOST=36.92.47.218
MQTT_PORT=14583

# Filter RSSI (dBm) — sinyal lebih lemah dari ini diabaikan
RSSI_MIN=-80

# Debounce lokal di Pi (detik)
DEBOUNCE_LOCAL=30

# Interval heartbeat ke server (detik)
HEARTBEAT_SECS=30
